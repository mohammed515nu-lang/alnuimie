    "eas:android:aab": "eas build --platform android --profile production",
    "eas:android:apk": "eas build --platform android --profile production-apk",
    "eas:android:standalone": "eas build --platform android --profile production",
    "eas:android:dev": "eas build --platform android --profile development",
    "prebuild:android": "expo prebuild --platform android",
    "assets:png": "node scripts/materialize-png-assets.mjs"
  },
  "dependencies": {
