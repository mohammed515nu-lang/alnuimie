# =============================================================================
#  سيرفر — قالب فقط (لا تضع مفاتيح حقيقية هنا إن رفعت المستودع)
# انسخ المحتوى إلى `.env` في هذا المجلد؛ server.js يحمّل `server/.env` عبر dotenv
# =============================================================================

PORT=4000
NODE_ENV=development

# خلف Render: اتركه فارغاً (الافتراضي trust أول بروكسي). للتعطيل محلياً: TRUST_PROXY=0
# TRUST_PROXY=0

MONGODB_URI=mongodb://localhost:27017/construction-management

JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET

FRONTEND_URL=http://localhost:8081

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# مساعد بنيان AI — NVIDIA (على الخادم فقط؛ لا تضع المفتاح في تطبيق Expo)
# انسخ معرّف النموذج من: https://build.nvidia.com أو وثائق NIM
# -----------------------------------------------------------------------------
NVIDIA_API_KEY=
# نموذج رئيسي: إما FAST أو MODEL (أحدهما على الأقل مطلوب في الإنتاج)
# NVIDIA_CHAT_MODEL_FAST=meta/llama-3.1-8b-instruct
NVIDIA_CHAT_MODEL=
# نموذج احتياطي اختياري عند فشل الأول (429، خطأ، إلخ):
# NVIDIA_CHAT_MODEL_FALLBACK=meta/llama-3.1-70b-instruct
# إن عُيّن FAST و MODEL وكانا مختلفين ولم تُضبط FALLBACK، يُستخدم MODEL تلقائياً كنموذج ثانٍ.
# NVIDIA_API_BASE_URL=https://integrate.api.nvidia.com/v1
# NVIDIA_CHAT_TIMEOUT_MS=120000
# (حتى 480000 إن لزم؛ يجب أن يبقى طلب التطبيق أطول من هذه المهلة — انظر ai.ts)
# NVIDIA_MAX_TOKENS=480
# NVIDIA_TEMPERATURE=0.35
