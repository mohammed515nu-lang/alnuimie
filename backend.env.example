# =============================================================================
#  سيرفر — Node / Express (مجلد السيرفر الذي يحتوي server.js)
# =============================================================================
# 1) انسخ هذا الملف إلى مجلد السيرفر وسمّه `.env`
# 2) عدّل القيم ثم أعد تشغيل السيرفر.
# =============================================================================

# المنفذ الافتراضي في server.js: 4000
PORT=4000

# development | production
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/construction-management

# توقيع JWT — استخدم سلسلة عشوائية طويلة في الإنتاج (لا تشاركها)
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET

# رابط الواجهة (ويب أو Expo) لروابط OAuth وإعادة تعيين كلمة المرور
FRONTEND_URL=http://localhost:8081

# Google OAuth (اختياري — اتركه فارغاً إن لم تستخدمه)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Stripe — السيرفر (مفاتيح سرية + ويب هوك)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
