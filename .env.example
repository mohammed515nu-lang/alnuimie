# =============================================================================
#  فرونت — تطبيق Expo  (هذا الملف قالب فقط — لا تضع فيه أسراراً حقيقية)
# =============================================================================
# 1) انسخ *المحتوى* إلى ملف جديد اسمه `.env` في نفس المجلد (أو انسخ الملف ثم سمّ النسخة `.env`).
# 2) اترك `.env.example` في Git كمرجع للفريق؛ ملف `.env` محلي ولا يُرفع (مذكور في .gitignore).
#
# Expo يقرأ EXPO_PUBLIC_* عند `expo start` وعند `eas build` إذا عرّفتها في EAS
# (Project → Environment variables) أو في ملف `.env` المحلي قبل البناء.
#
# تطوير على جهاز حقيقي: لا تستخدم localhost — استخدم IP الشبكة أو الاستضافة.
# إنتاج (APK يُوزَّع للمستخدمين): عيّن EXPO_PUBLIC_API_URL لرابط HTTPS ينتهي بـ /api
# مثال الإنتاج (ريندر): https://alnuimie.onrender.com/api
# مثال التطوير المحلي: http://192.168.x.x:4000/api
# =============================================================================

# عنوان واجهة الـ API (ينتهي بـ /api) — الافتراضي في app.config يشير لبنك alnuimie
EXPO_PUBLIC_API_URL=https://alnuimie.onrender.com/api

# Stripe — المفتاح العام فقط (pk_test_ أو pk_live_)؛ يجب أن يطابق وضع مفاتيح الخادم
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# إظهار زر تسجيل الدخول بـ Google؛ يتطلب Web Client ID ونفس redirect URI المسجّل على Google + الخادم
EXPO_PUBLIC_ENABLE_GOOGLE_AUTH=false
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_OAUTH_REDIRECT_URI=https://alnuimie515.vercel.app/auth/google/callback

# =============================================================================
#  مساعد بنيان (AI) — مهم
# =============================================================================
# التطبيق يستدعي فقط: POST {EXPO_PUBLIC_API_URL}/ai/ask مع JWT.
# مفتاح NVIDIA يُضاف على السيرفر (مجلد server/.env أو متغيرات Render)،
# كـ NVIDIA_API_KEY و NVIDIA_CHAT_MODEL — لا تستخدم EXPO_PUBLIC_ لمفتاح نفيديا
# (لأنه يُنسخ داخل حزمة التطبيق ويُسرق بسهولة).
# =============================================================================
